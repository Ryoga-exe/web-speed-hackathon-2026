{
  "extends": ["@tsconfig/strictest/tsconfig.json"],
  "compilerOptions": {
    "noEmit": true,
    "checkJs": true,
    "jsx": "react-jsx",
    "target": "esnext",
    "lib": ["DOM", "ESNext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noUnusedLocals": false,
    "paths": {
      "@web-speed-hackathon-2026/client/*": ["./*"]
    },
    "exactOptionalPropertyTypes": false
  },
  "include": ["./src", "./types"]
}
